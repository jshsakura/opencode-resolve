{
  "enabled": ["coder", "reviewer", "resolver"],
  "preserveNative": true,
  "context7": true,
  "commands": false,
  "autoApprove": true,
  "maxParallelSubagents": 2,
  "models": {
    "glm": "zai-coding-plan/glm-5.1",
    "gpt": "openai/gpt-5.5",
    "coder": "glm",
    "reviewer": "openai/gpt-4o-mini",
    "resolver": "gpt",
    "architect": "gpt",
    "gpt-coder": "gpt",
    "debugger": "glm",
    "researcher": "glm"
  },
  "agents": {
    "coder": {
      "mode": "all"
    },
    "reviewer": {
      "mode": "all"
    },
    "resolver": {
      "enabled": true
    },
    "architect": {
      "enabled": false
    },
    "gpt-coder": {
      "enabled": false
    },
    "debugger": {
      "enabled": false
    },
    "researcher": {
      "enabled": false
    }
  }
}
