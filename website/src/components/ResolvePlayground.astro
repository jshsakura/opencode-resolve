---
import BuildInfo from "./BuildInfo.astro";

type Locale = "en" | "ko";

const { locale = "en" } = Astro.props as { locale?: Locale };

const copy = {
  en: {
    badge: "Live workflow",
    title: "End-to-end task loop",
    subtitle: "A small resolver/coder path that keeps implementation, verification, and reporting moving in one flow.",
    roles: "Roles",
    commands: "Setup path",
    checkpoint: "Checkpoint",
    copy: "Copy",
    copied: "Copied",
    runNext: "Run next checkpoint",
    terminalTitle: "resolver session",
    commandTabs: [
      {
        id: "npm",
        label: "Standard",
        command: "npm install -g opencode-resolve\nopencode",
        note: "Install once. The postinstall registers the plugin and refreshes stale OpenCode cache entries.",
      },
      {
        id: "refresh",
        label: "Refresh",
        command: "opencode plugin opencode-resolve --global --force\nopencode",
        note: "Use when you want to force OpenCode's plugin cache to reinstall the current package.",
      },
      {
        id: "skills",
        label: "Skills",
        command: "curl -sL https://raw.githubusercontent.com/jshsakura/awesome-opencode-skills/main/install.sh | bash",
        note: "Optional: add a broad OpenCode Skills collection for domain-specific work.",
      },
    ],
    rolesData: [
      {
        id: "resolver",
        label: "resolver",
        tone: "cyan",
        title: "Orchestrates the task",
        body: "Reads only relevant context, dispatches focused subagents, verifies each checkpoint, and keeps progress moving.",
        status: "primary",
      },
      {
        id: "coder",
        label: "coder",
        tone: "rose",
        title: "Applies the patch",
        body: "Owns focused implementation, file edits, targeted tests, diagnostics, and the changed-file report.",
        status: "subagent",
      },
      {
        id: "explorer",
        label: "explorer",
        tone: "emerald",
        title: "Scouts the codebase",
        body: "Finds files, APIs, and patterns quickly without modifying the project.",
        status: "read-only",
      },
      {
        id: "reviewer",
        label: "reviewer",
        tone: "amber",
        title: "Checks verification gaps",
        body: "Reviews correctness, missing tests, security, and residual risk without writing files.",
        status: "read-only",
      },
    ],
    steps: [
      ["user", "Fix the failing settings save flow and verify it."],
      ["resolver", "Inspect scoped routes, locate save handler, dispatch coder with exact files."],
      ["coder", "Patch validation edge case, run targeted test, check diagnostics."],
      ["reviewer", "No blocking findings. Remaining risk: integration smoke not run."],
      ["resolver", "Report changed files, test evidence, and residual risk."],
    ],
  },
  ko: {
    badge: "실시간 워크플로우",
    title: "종단간 작업 루프",
    subtitle: "구현, 검증, 보고가 하나의 흐름으로 이어지는 소규모 resolver/coder 경로입니다.",
    roles: "에이전트 역할",
    commands: "설치 경로",
    checkpoint: "체크포인트",
    copy: "복사",
    copied: "복사됨",
    runNext: "다음 단계 실행",
    terminalTitle: "리졸버 세션",
    commandTabs: [
      {
        id: "npm",
        label: "표준 설치",
        command: "npm install -g opencode-resolve\nopencode",
        note: "한 번만 설치하면 됩니다. 설치 후 자동으로 플러그인이 등록되고 캐시가 갱신됩니다.",
      },
      {
        id: "refresh",
        label: "캐시 갱신",
        command: "opencode plugin opencode-resolve --global --force\nopencode",
        note: "플러그인 캐시를 강제로 다시 설치하고 설정을 초기화하고 싶을 때 사용합니다.",
      },
      {
        id: "skills",
        label: "스킬 추가",
        command: "curl -sL https://raw.githubusercontent.com/jshsakura/awesome-opencode-skills/main/install.sh | bash",
        note: "선택 사항: 특정 도메인 작업에 특화된 OpenCode Skills 모음을 추가합니다.",
      },
    ],
    rolesData: [
      {
        id: "resolver",
        label: "리졸버",
        tone: "cyan",
        title: "작업 전체 조율",
        body: "관련 컨텍스트만 읽고, 필요한 하위 에이전트를 할당하며, 각 단계를 검증하여 진행을 이끕니다.",
        status: "메인",
      },
      {
        id: "coder",
        label: "코더",
        tone: "rose",
        title: "패치 및 구현",
        body: "코드 수정, 테스트 실행, 진단 확인 및 변경된 파일 보고서 작성을 전담합니다.",
        status: "서브",
      },
      {
        id: "explorer",
        label: "익스플로러",
        tone: "emerald",
        title: "코드베이스 탐색",
        body: "프로젝트를 수정하지 않고 파일, API, 패턴을 빠르게 찾아냅니다.",
        status: "읽기 전용",
      },
      {
        id: "reviewer",
        label: "리뷰어",
        tone: "amber",
        title: "검증 공백 확인",
        body: "수정사항의 정확성, 누락된 테스트, 보안 및 잔여 위험을 파일 수정 없이 검토합니다.",
        status: "읽기 전용",
      },
    ],
    steps: [
      ["user", "설정 저장 로직의 오류를 수정하고 검증해줘."],
      ["resolver", "Save handler를 찾은 뒤 coder에 정확한 파일을 넘깁니다."],
      ["coder", "validation edge case를 패치하고 대상 테스트와 diagnostics를 확인합니다."],
      ["reviewer", "차단 이슈 없음. 잔여 위험: integration smoke 미실행."],
      ["resolver", "변경 파일, 테스트 증거, 잔여 위험을 보고합니다."],
    ],
  },
}[locale];

const serialized = JSON.stringify(copy);
---

<section class="resolve-playground" data-resolve-playground data-copy={serialized}>
  <div class="playground-head">
    <span class="status-badge">
      <span class="status-pulse"></span>
      {copy.badge}
    </span>
    <div>
      <h2>{copy.title}</h2>
      <p>{copy.subtitle}</p>
    </div>
  </div>

  <div class="playground-grid">
    <div class="playground-grid-row">
      <!-- Panel 1: Roles -->
      <div class="panel panel-roles">
        <div class="panel-title">{copy.roles}</div>
        <div class="panel-tabs-area">
          <div class="tabs-container" role="tablist">
            {copy.rolesData.map((role, index) => (
              <button
                type="button"
                class={`tab-item ${index === 0 ? "is-active" : ""}`}
                data-role-tab={role.id}
                data-tone={role.tone}
              >
                {role.label}
              </button>
            ))}
          </div>
        </div>
        <div class="panel-content-area">
          <div class="role-card" data-role-card>
            <div class="role-card-top">
              <span class="role-chip" data-role-chip>{copy.rolesData[0].label}</span>
              <span class="role-mode" data-role-mode>{copy.rolesData[0].status}</span>
            </div>
            <h3 data-role-title>{copy.rolesData[0].title}</h3>
            <p data-role-body>{copy.rolesData[0].body}</p>
          </div>
        </div>
      </div>

      <!-- Panel 2: Setup path -->
      <div class="panel panel-command">
        <div class="panel-title">{copy.commands}</div>
        <div class="panel-tabs-area">
          <div class="tabs-container" role="tablist">
            {copy.commandTabs.map((tab, index) => (
              <button
                type="button"
                class={`tab-item ${index === 0 ? "is-active" : ""}`}
                data-command-tab={tab.id}
              >
                {tab.label}
              </button>
            ))}
          </div>
        </div>
        <div class="panel-content-area">
          <div class="command-box">
            <pre class="command-output"><code data-command-output>{copy.commandTabs[0].command}</code></pre>
            <div class="command-footer">
              <p data-command-note>{copy.commandTabs[0].note}</p>
              <button type="button" class="copy-button" data-copy-command>{copy.copy}</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Terminal Panel -->
    <div class="panel panel-terminal">
      <div class="terminal-demo compact">
        <div class="terminal-bar">
          <span class="terminal-dot" style="background:#fb7185"></span>
          <span class="terminal-dot" style="background:#fbbf24"></span>
          <span class="terminal-dot" style="background:#34d399"></span>
          <span class="terminal-title">{copy.terminalTitle}</span>
        </div>
        <div class="terminal-body" data-terminal-body>
          {copy.steps.slice(0, 3).map(([role, text]) => (
            <p class="terminal-line">
              <span class="terminal-role">{role}</span>
              <span class="terminal-text">{text}</span>
            </p>
          ))}
        </div>
      </div>
      <div class="checkpoint-row">
        <span>{copy.checkpoint} <strong data-step-count>3</strong> / 5</span>
        <button type="button" class="copy-button secondary" data-next-step>{copy.runNext}</button>
      </div>
    </div>
  </div>
  <BuildInfo />
</section>

<script type="module">
  const playgrounds = document.querySelectorAll("[data-resolve-playground]");
  for (const playground of playgrounds) {
    const data = JSON.parse(playground.getAttribute("data-copy") || "{}");
    let currentCommand = data.commandTabs?.[0]?.command || "";
    let visibleSteps = 3;

    // Roles switching with fade transition and auto-advance
    const roleTabs = playground.querySelectorAll("[data-role-tab]");
    const roleChip = playground.querySelector("[data-role-chip]");
    const roleMode = playground.querySelector("[data-role-mode]");
    const roleTitle = playground.querySelector("[data-role-title]");
    const roleBody = playground.querySelector("[data-role-body]");
    const roleCard = playground.querySelector("[data-role-card]");
    const rolesPanel = playground.querySelector(".panel-roles");

    const ROLE_SWAP_MS = 180;
    const ROLE_AUTOPLAY_MS = 3500;
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let currentRoleIdx = 0;
    let autoplayPaused = false;
    let autoplayStopped = reducedMotion;
    let roleAutoplayTimer = null;

    function applyRole(role, tab) {
      roleTabs.forEach((t) => t.classList.remove("is-active"));
      tab.classList.add("is-active");
      if (!roleCard) return;
      if (reducedMotion) {
        roleCard.setAttribute("data-tone", role.tone);
        if (roleChip) roleChip.textContent = role.label;
        if (roleMode) roleMode.textContent = role.status;
        if (roleTitle) roleTitle.textContent = role.title;
        if (roleBody) roleBody.textContent = role.body;
        return;
      }
      roleCard.classList.add("is-swapping");
      setTimeout(() => {
        roleCard.setAttribute("data-tone", role.tone);
        if (roleChip) roleChip.textContent = role.label;
        if (roleMode) roleMode.textContent = role.status;
        if (roleTitle) roleTitle.textContent = role.title;
        if (roleBody) roleBody.textContent = role.body;
        roleCard.classList.remove("is-swapping");
      }, ROLE_SWAP_MS);
    }

    function selectRole(tab) {
      const id = tab.getAttribute("data-role-tab");
      const role = data.rolesData.find((item) => item.id === id);
      if (!role) return;
      applyRole(role, tab);
      currentRoleIdx = Array.from(roleTabs).indexOf(tab);
    }

    for (const tab of roleTabs) {
      tab.addEventListener("click", (event) => {
        if (event.isTrusted) {
          autoplayStopped = true;
          if (roleAutoplayTimer) {
            clearInterval(roleAutoplayTimer);
            roleAutoplayTimer = null;
          }
        }
        selectRole(tab);
      });
    }

    function advanceRole() {
      if (autoplayStopped || autoplayPaused || roleTabs.length === 0) return;
      const nextIdx = (currentRoleIdx + 1) % roleTabs.length;
      selectRole(roleTabs[nextIdx]);
    }

    if (!reducedMotion && roleTabs.length > 1) {
      roleAutoplayTimer = setInterval(advanceRole, ROLE_AUTOPLAY_MS);
      rolesPanel?.addEventListener("mouseenter", () => { autoplayPaused = true; });
      rolesPanel?.addEventListener("mouseleave", () => { autoplayPaused = false; });
    }

    // Command switching
    const commandTabs = playground.querySelectorAll("[data-command-tab]");
    const commandOutput = playground.querySelector("[data-command-output]");
    const commandNote = playground.querySelector("[data-command-note]");
    const copyBtn = playground.querySelector("[data-copy-command]");

    for (const tab of commandTabs) {
      tab.addEventListener("click", () => {
        const id = tab.getAttribute("data-command-tab");
        const item = data.commandTabs.find((t) => t.id === id);
        if (item) {
          commandTabs.forEach((t) => t.classList.remove("is-active"));
          tab.classList.add("is-active");
          currentCommand = item.command;
          if (commandOutput) commandOutput.textContent = item.command;
          if (commandNote) commandNote.textContent = item.note;
        }
      });
    }

    // Copying
    copyBtn?.addEventListener("click", async () => {
      await navigator.clipboard.writeText(currentCommand);
      const original = data.copy;
      copyBtn.textContent = data.copied;
      setTimeout(() => {
        copyBtn.textContent = original;
      }, 1400);
    });

    // Terminal progression
    const terminalBody = playground.querySelector("[data-terminal-body]");
    const stepCount = playground.querySelector("[data-step-count]");
    const nextStep = playground.querySelector("[data-next-step]");

    const renderSteps = () => {
      if (terminalBody) {
        terminalBody.innerHTML = data.steps
          .slice(0, visibleSteps)
          .map(
            ([role, text]) =>
              `<p class="terminal-line"><span class="terminal-role">${role}</span><span class="terminal-text">${text}</span></p>`
          )
          .join("");
      }
      if (stepCount) stepCount.textContent = String(visibleSteps);
    };

    nextStep?.addEventListener("click", () => {
      visibleSteps = visibleSteps >= data.steps.length ? 1 : visibleSteps + 1;
      renderSteps();
    });
  }
</script>
